# Core Django
SECRET_KEY=replace-with-secure-key
DEBUG=True

# AI configuration
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here
CV_ANALYSIS_USE_LLM=true
CV_OPENAI_MODEL=gpt-4o-mini
CV_OPENAI_TIMEOUT_SECONDS=45

# Optional future toggles (keep false until RAG/LangGraph pipeline is implemented)
CV_ENABLE_RAG=false
CV_ENABLE_LANGGRAPH=false

# Optional tool integrations
TAVILY_API_KEY=
